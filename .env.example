# Alpaca Markets — paper trading credentials
# Copy this file to .env for local runs (never commit .env)
# In GitHub Actions these are set as repository secrets:
#   Settings → Secrets and variables → Actions → New repository secret

ALPACA_ACCOUNT_NAME=TradeQuest Paper           # display label shown in dashboard
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic — Claude AI agent (day-start, day-end, monthly rebalance decisions)
# Get your key at https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# How to get your Alpaca paper trading keys:
# 1. Sign up free at https://alpaca.markets
# 2. Switch to Paper Trading in the dashboard
# 3. Go to API Keys → Generate New Key
# 4. Copy the Key ID → ALPACA_API_KEY
# 5. Copy the Secret Key → ALPACA_SECRET_KEY (shown only once)
